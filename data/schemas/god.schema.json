{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "god.schema.json",
  "$comment": "v4 — a member of the Pantheon of the Drowned; adds wakerWhispers (VILLAGER-AND-GODHEAD-SPEC Part II §5 — Ur-Noth's whisper-on-wake pools, optional, additive; existing gods need no changes)",
  "type": "object",
  "required": ["id", "name", "title", "domain", "voice", "blessing", "invocations", "priest"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^god-[a-z0-9-]+$" },
    "name": { "type": "string" },
    "workingName": { "type": "boolean" },
    "title": { "type": "string" },
    "domain": { "type": "string", "description": "one-line domain summary" },
    "voice": {
      "type": "object",
      "description": "prompt-kit for generating this god's dreams/whispers/rite lines",
      "required": ["tone", "imagery", "sampleLine"],
      "properties": {
        "tone": { "type": "string" },
        "imagery": { "type": "array", "items": { "type": "string" } },
        "sampleLine": { "type": "string" }
      }
    },
    "blessing": {
      "type": "object",
      "required": ["name", "text", "effectsByRank"],
      "properties": {
        "name": { "type": "string" },
        "text": { "type": "string" },
        "effectsByRank": {
          "type": "array", "minItems": 3, "maxItems": 3,
          "items": { "$ref": "common.schema.json#/$defs/effectList" }
        }
      }
    },
    "invocations": {
      "type": "array", "minItems": 2, "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "name", "rankRequired", "vigorCost", "text", "effects"],
        "properties": {
          "id": { "type": "string", "pattern": "^inv-[a-z0-9-]+$" },
          "name": { "type": "string" },
          "rankRequired": { "type": "integer", "minimum": 1, "maximum": 3 },
          "vigorCost": { "type": "number", "exclusiveMinimum": 0, "description": "fraction of this god's max Vigor, 0-1" },
          "selfCost": { "$ref": "common.schema.json#/$defs/effectList", "description": "Ur-Noth pattern: permanent costs to the caster" },
          "text": { "type": "string" },
          "effects": { "$ref": "common.schema.json#/$defs/effectList" }
        }
      }
    },
    "priest": {
      "type": "object",
      "required": ["title", "arrival"],
      "properties": {
        "title": { "type": "string" },
        "arrival": { "type": "string", "description": "diegetic arrival condition beyond the chapel requirement" },
        "notes": { "type": "string" }
      }
    },
    "vigor": {
      "type": "object",
      "description": "overrides of tuning/economy.json defaults",
      "properties": {
        "maxVigor": { "type": "number" },
        "riteRecoveryMult": { "type": "number" }
      }
    },
    "flags": {
      "type": "array",
      "items": { "enum": ["drains-caster", "strengthened-by-withdrawal", "expensive-to-leave", "missing"] }
    },
    "affinityLegendIds": { "type": "array", "items": { "type": "string" } },
    "offerings": {
      "type": "object",
      "description": "the Sanctum: this god's appetite table for the Offertory (craves x2, accepts x1, ignores x0, offends = negative + writes the Verdict ledgers)",
      "properties": {
        "craves": { "type": "array", "items": { "type": "string", "pattern": "^item-[a-z0-9-]+$" } },
        "accepts": { "type": "array", "items": { "type": "string", "pattern": "^item-[a-z0-9-]+$" } },
        "offends": { "type": "array", "items": { "type": "string", "pattern": "^item-[a-z0-9-]+$" } }
      },
      "additionalProperties": false
    },
    "worshipChant": { "type": "string", "description": "sfx asset basename (in assets/sfx/) played at this god's rite; falls back to the generic rite bell if the file is absent" },
    "lore": { "type": "string" },
    "wakerWhispers": {
      "type": "object",
      "description": "VILLAGER-AND-GODHEAD-SPEC Part II §5: the Waker's whisper-on-wake lines, one drawn each player death, keyed by lifetime death count (tuning/godhead.json waker.whisperPoolThresholds picks the pool). Ur-Noth only at EA (he alone restores dead players) but schema'd generically in case that ever changes.",
      "required": ["early", "familiar", "proprietary"],
      "additionalProperties": false,
      "properties": {
        "early": { "type": "array", "items": { "type": "string" }, "minItems": 1, "description": "curious — early deaths" },
        "familiar": { "type": "array", "items": { "type": "string" }, "minItems": 1, "description": "he knows your habits" },
        "proprietary": { "type": "array", "items": { "type": "string" }, "minItems": 1, "description": "you are mostly his to lose" },
        "milestones": {
          "type": "object",
          "description": "exact lifetime-death-count -> a single one-off flavor line (pure whisper content, NOT the parked debt-milestone Callings)",
          "additionalProperties": { "type": "string" },
          "propertyNames": { "pattern": "^[0-9]+$" }
        }
      }
    }
  }
}
