{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "item.schema.json",
  "$comment": "v1",
  "type": "object",
  "required": ["id", "name", "category", "text"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^item-[a-z0-9-]+$" },
    "name": { "type": "string" },
    "workingName": { "type": "boolean" },
    "category": { "enum": ["material", "tool", "weapon", "armor", "food", "offering", "remnant", "relic", "misc"] },
    "tier": { "type": "integer", "minimum": 0, "maximum": 3 },
    "stackSize": { "type": "integer", "minimum": 1, "default": 20 },
    "stats": { "type": "object", "additionalProperties": { "type": "number" } },
    "effects": { "$ref": "common.schema.json#/$defs/effectList" },
    "offeringValue": { "type": "number", "description": "worship-rate buydown value; offerings only" },
    "remnantOf": { "type": "string", "description": "remnants only: the god this fragment belongs to — consuming it dims THEM, world-wide" },
    "legend": {
      "type": "object",
      "description": "Track-2 named artifacts only",
      "required": ["godAffinity", "history"],
      "properties": {
        "godAffinity": { "type": "string", "description": "god-* id; rank-2+ attunement to wield" },
        "history": { "type": "string", "description": "every legend is named and has a paragraph of history" }
      },
      "additionalProperties": false
    },
    "text": { "type": "string" }
  }
}
