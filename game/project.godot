; The Dried Sea — Godot 4 project (Soul Build)
; M0 fleshes this out: sim/ (pure, headless-testable), scenes/ (thin), tests/.
; Engine version pinned at M0 start.

config_version=5

[application]

config/name="The Dried Sea"
config/features=PackedStringArray("4.3")
run/main_scene="res://scenes/main.tscn"

[debug]

gdscript/warnings/treat_warnings_as_errors=false
gdscript/warnings/inference_on_variant=0
gdscript/warnings/untyped_declaration=0

[rendering]

renderer/rendering_method="mobile"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
